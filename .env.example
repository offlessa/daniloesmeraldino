# Exemplo de arquivo .env
# Copie este arquivo para .env e preencha com seus valores

# WhatsApp Number (formato: 55 + DDD + número)
VITE_WHATSAPP_NUMBER=554832345678

# Email da empresa
VITE_COMPANY_EMAIL=contato@metrica.com.br

# Telefone da empresa (com máscara)
VITE_COMPANY_PHONE=(48) 3234-5678

# URL da empresa (para SEO)
VITE_COMPANY_URL=https://metrica-construcoes.com.br

# Analytics (opcional)
VITE_GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X
